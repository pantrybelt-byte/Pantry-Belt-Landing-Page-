rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Waitlist: public create-only with schema validation
    match /waitlist/{docId} {
      allow read:             if false;
      allow create:           if isValidWaitlistEntry();
      allow update, delete:   if false;
    }

    // Pantries: read-only public (mobile app)
    match /pantries/{docId} {
      allow read:             if true;
      allow write:            if false;
    }

    // Analytics / Searches / Users: deny all from web
    match /analytics/{docId=**} {
      allow read, write: if false;
    }
    match /searches/{docId=**} {
      allow read, write: if false;
    }
    match /users/{docId=**} {
      allow read, write: if false;
    }

    // Mail: Deny all web client access (used by Cloud Functions only)
    match /mail/{docId} {
      allow read, write: if false;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Validation function for waitlist entries
    function isValidWaitlistEntry() {
      let d = request.resource.data;
      return d.keys().hasAll(['name', 'email', 'phone_sms', 'created_at'])
          && d.keys().hasOnly(['name', 'email', 'phone_sms', 'created_at'])
          && d.name is string
          && d.name.size() > 0
          && d.email is string
          && d.email.matches('^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$')
          && d.phone_sms is string
          && d.phone_sms.matches('^\\+1[0-9]{10}$')
          && d.created_at is timestamp;
    }
  }
}
